# Supabase (run `supabase start` for local defaults)
# NEXT_PUBLIC_ vars are shared by both the Next.js frontend and the Hono API server.
# SUPABASE_SECRET_KEY is server-only (never expose to the browser).
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key-here
SUPABASE_SECRET_KEY=your-secret-key-here

# API server (Hono backend)
NEXT_PUBLIC_API_URL=http://localhost:3001
# API_PORT=3001
# Comma-separated origins allowed by the API's CORS policy
# CORS_ORIGIN=http://localhost:3000

# Optional: Tiingo API key for live security quotes
# (the quotes endpoint returns 503 when unset)
# TIINGO_API_KEY=your-tiingo-key
